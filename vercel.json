{
  "builds": [
    { "src": "server/src/index.js", "use": "@vercel/node" },
    { "src": "server/src/api/client.js", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "favicon.svg", "use": "@vercel/static" },
    { "src": "dist/styles.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/src/index.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
